{
  "_name": "Large optimization config - 120 agents, 2000 episodes",
  "nagents": 120,
  "capacity": 40000,
  "learning_rate": 0.0005,
  "momentum": 0.005,
  "tau": 0.005,
  "batch_size": 256,
  "gamma": 0.9,

  "min_memory_for_learning": 32,
  "action_strategy": "langevin",

  "epsilon_policy": "linear_increasing",
  "eps_min": 0.0,
  "eps_max": 0.9,
  "eps_increment": 0.001,
  "eps_start": 1.0,
  "eps_end": 0.05,
  "eps_decay_steps": 200000,

  "nepisodes": 2000,
  "nsteps": 200,
  "nupdate": 50,

  "early_termination": true,
  "learn_every": 1,
  "use_amp": true,
  "metrics_interval": 10,
  "diag_interval": 10,
  "parallel_agent_optimization": true,
  "parallel_opt_max_streams": 4,
  "multi_gpu_auto": true,
  "multi_gpu_min_memory_gb": 8.0,
  "batch_size_auto": true,
  "batch_size_vram_fraction": 0.6,
  "batch_size_min": 128,
  "batch_size_max": 4096,
  "batch_size_grad_overhead": 5.0,
  "cuda": 0,

  "enable_plot": true,
  "plot_interval": 200,
  "plot_smooth_window": 200,
  "plot_x_axis": "episodes",
  "step_log_throttle": 20,
  "checkpoint_interval": 200,

  "_doc": {
    "nagents": "Number of agents (UEs). Also sets DNN input size in RL.",
    "capacity": "Replay buffer capacity per agent (number of transitions).",
    "learning_rate": "Optimizer learning rate.",
    "tau": "Soft target network update rate.",
    "min_memory_for_learning": "Minimum transitions before learning starts.",
    "action_strategy": "Action selection: epsilon_greedy, greedy, langevin, or boltzmann.",
    "epsilon_policy": "'linear_increasing' (original) or 'exponential_decay' (standard RL).",
    "nepisodes": "Number of training episodes.",
    "nsteps": "Max steps per episode.",
    "checkpoint_interval": "Save checkpoints every N episodes (0 disables)."
  }
}
