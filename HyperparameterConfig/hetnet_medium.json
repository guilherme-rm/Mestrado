{
  "_description": "HetNet medium preset — combined scenario + optimization hyperparameters. Documentation only.",
  "_source_sce": "Config/hetnet/config_sce_medium.json",
  "_source_opt": "Config/opt/config_opt_medium.json",
  "_baseline": "Matches Result_main/medium-flat run.",

  "scenario": {
    "environment": "hetnet",
    "nMBS": 4,
    "nPBS": 16,
    "nFBS": 32,
    "BS_Number": 52,
    "rMBS_m": 500,
    "rPBS_m": 100,
    "rFBS_m": 30,
    "BW_Hz": 180000,
    "nChannel": 50,
    "N0_dBm_per_Hz": -174,
    "QoS_thr_dB": 5,
    "profit": 0.5,
    "power_cost": 0.0005,
    "action_cost": 0.001,
    "negative_cost": -1.0
  },

  "optimization": {
    "nagents": 60,
    "action_space_size": "52 BS * 50 channels = 2600",
    "capacity_per_agent": 20000,
    "learning_rate": 0.001,
    "momentum": 0.005,
    "tau": 0.005,
    "batch_size": 128,
    "gamma": 0.9,
    "min_memory_for_learning": 16,
    "action_strategy": "langevin",
    "epsilon_policy": "linear_increasing",
    "eps_min": 0.0,
    "eps_max": 0.9,
    "eps_increment": 0.002,
    "eps_start": 1.0,
    "eps_end": 0.05,
    "eps_decay_steps": 100000,
    "nepisodes": 1000,
    "nsteps": 100,
    "nupdate": 50,
    "early_termination": true,
    "learn_every": 1,
    "use_amp": true,
    "metrics_interval": 10,
    "diag_interval": 10,
    "parallel_agent_optimization": true,
    "parallel_opt_max_streams": 4,
    "multi_gpu_auto": true,
    "multi_gpu_min_memory_gb": 8.0,
    "batch_size_auto": false,
    "batch_size_vram_fraction": 0.6,
    "batch_size_min": 64,
    "batch_size_max": 4096,
    "batch_size_grad_overhead": 5.0,
    "cuda": 0,
    "plot_interval": 100,
    "plot_smooth_window": 100,
    "step_log_throttle": 10,
    "checkpoint_interval": 100
  }
}
